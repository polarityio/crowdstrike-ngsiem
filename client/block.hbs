{{! ══════════════════════════════════════════════ }}
{{! Deep link — always at top for instant pivot  }}
{{! ══════════════════════════════════════════════ }}
<div class="csng-deep-link-row">
  <span class="p-key">Falcon NG-SIEM:</span>
  <span class="p-value">
    <a href={{details.deepLink}} class="csng-deep-link">
      {{fa-icon "external-link-alt" fixedWidth=true}} Open in Falcon
    </a>
  </span>
</div>

{{! ══════════════════════════════════════════════ }}
{{! Query metadata                                }}
{{! ══════════════════════════════════════════════ }}
<div>
  <span class="p-key">Query:</span>
  <span class="p-value csng-query-mono">{{details.query}}</span>
</div>
<div>
  <span class="p-key">Window:</span>
  <span class="p-value">{{details.searchWindow}} &rarr; now</span>
</div>

{{! ══════════════════════════════════════════════ }}
{{! Repository selector (collapsible)             }}
{{! ══════════════════════════════════════════════ }}
<div class="csng-section-toggle" {{action "toggleSection" "RepoSelector"}}>
  <span class="p-title">
    {{fa-icon "database" fixedWidth=true}} Repositories
  </span>
  <span class="csng-chevron">
    {{#if block._state.showRepoSelector}}
      {{fa-icon "chevron-up"}}
    {{else}}
      {{fa-icon "chevron-down"}}
    {{/if}}
  </span>
</div>

{{#if block._state.showRepoSelector}}
  <div class="csng-repo-picker">
    {{#each details.availableRepositories as |repo|}}
      <div
        class="csng-repo-toggle {{if (get block._state.selectedRepos repo.value) "csng-repo-active"}}"
        {{action "toggleRepo" repo.value}}
      >
        {{#if (get block._state.selectedRepos repo.value)}}
          {{fa-icon "check-square" fixedWidth=true}}
        {{else}}
          {{fa-icon "square" fixedWidth=true}}
        {{/if}}
        {{repo.label}}
      </div>
    {{/each}}

    <button
      class="btn btn-xs btn-default csng-run-btn"
      {{action "runQuery"}}
    >
      {{#if block._state.isQuerying}}
        {{fa-icon "spinner" spin=true fixedWidth=true}} Querying...
      {{else}}
        {{fa-icon "search" fixedWidth=true}} Run Query
      {{/if}}
    </button>
  </div>
{{/if}}

{{! ══════════════════════════════════════════════ }}
{{! Error state                                   }}
{{! ══════════════════════════════════════════════ }}
{{#if block._state.error}}
  <div class="csng-error">
    {{fa-icon "exclamation-triangle" fixedWidth=true}} {{block._state.error}}
  </div>
{{/if}}

{{! ══════════════════════════════════════════════ }}
{{! Results — one section per repository          }}
{{! ══════════════════════════════════════════════ }}
{{#each details.repoResults as |repoResult|}}
  <div class="csng-repo-section">

    {{! Repo header }}
    <div class="csng-repo-header">
      <span class="p-title">
        {{fa-icon "server" fixedWidth=true}} {{repoResult.label}}
      </span>
      {{#if repoResult.done}}
        {{#if repoResult.cancelled}}
          <span class="csng-badge csng-badge-cancelled">Cancelled</span>
        {{else}}
          <span class="csng-event-count">{{repoResult.events.length}} events</span>
        {{/if}}
      {{else}}
        <span class="csng-badge csng-badge-running">Running</span>
      {{/if}}
    </div>

    {{! ── Pending state: Check Status + Cancel ── }}
    {{#if (not repoResult.done)}}
      <div class="csng-pending-controls">
        <span class="csng-job-id">Job: {{repoResult.jobId}}</span>
        <button
          class="btn btn-xs btn-default csng-action-btn"
          {{action "checkStatus" repoResult.jobId repoResult.repositoryValue}}
        >
          {{fa-icon "sync" fixedWidth=true}} Check Status
        </button>
        <button
          class="btn btn-xs btn-danger csng-action-btn"
          {{action "cancelQuery" repoResult.jobId repoResult.repositoryValue}}
        >
          {{fa-icon "times" fixedWidth=true}} Cancel
        </button>
      </div>
    {{/if}}

    {{! ── Cancelled state ── }}
    {{#if repoResult.cancelled}}
      <div class="csng-no-events">Query was cancelled.</div>
    {{/if}}

    {{! ── Events list ── }}
    {{#if repoResult.done}}
      {{#if (not repoResult.cancelled)}}
        {{#if repoResult.events.length}}
          {{#each repoResult.events as |event eventIndex|}}
            <div class="csng-event-card">
              <div class="csng-event-num">
                {{fa-icon "file-alt" fixedWidth=true}} Event {{eventIndex}}
              </div>

              {{! Tab nav }}
              <ul class="nav nav-tabs csng-tabs">
                <li class="nav-item">
                  <a
                    href="#"
                    class="nav-link {{if (eq event.__activeTab "fields") "active"}}"
                    {{action "changeTab" "fields" repoResult.repositoryValue eventIndex}}
                  >Fields</a>
                </li>
                <li class="nav-item">
                  <a
                    href="#"
                    class="nav-link {{if (eq event.__activeTab "json") "active"}}"
                    {{action "changeTab" "json" repoResult.repositoryValue eventIndex}}
                  >JSON</a>
                </li>
              </ul>

              {{! Fields tab }}
              {{#if (eq event.__activeTab "fields")}}
                <div class="csng-fields-body">
                  {{#each-in event as |key value|}}
                    {{#if (and (not (eq key "__activeTab")) (not (eq key "__jsonHighlighted")))}}
                      <div>
                        <span class="p-key">{{key}}:</span>
                        <span class="p-value csng-field-value">{{value}}</span>
                      </div>
                    {{/if}}
                  {{/each-in}}
                </div>
              {{/if}}

              {{! JSON tab }}
              {{#if (eq event.__activeTab "json")}}
                <div class="csng-json-body">
                  <pre class="csng-json-pre">{{{event.__jsonHighlighted}}}</pre>
                </div>
              {{/if}}
            </div>
          {{/each}}
        {{else}}
          <div class="csng-no-events">No events found in this repository.</div>
        {{/if}}
      {{/if}}
    {{/if}}

  </div>
{{/each}}
